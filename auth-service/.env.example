# Servidor
PORT=3000

# Base de datos
DATABASE_URL=postgres://user:password@localhost:5432/auth_db?sslmode=disable

# Google OAuth obtenida en console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT: paths a las claves RSA generadas con:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Dominio permitido
ALLOWED_DOMAIN=@unal.edu.co

# TTL en segundos
ACCESS_TOKEN_TTL=900      # 15 minutos
REFRESH_TOKEN_TTL=604800  # 7 días
