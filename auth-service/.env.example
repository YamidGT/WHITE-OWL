# Servidor
PORT=4000

# Base de datos
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=auth_db

# Para desarrollo local (go run cmd/main.go)
DATABASE_URL=postgres://auth_user:changeme@localhost:5432/auth_db?sslmode=disable

# Para Docker (el host es el nombre del servicio en docker-compose)
DOCKER_DATABASE_URL=postgres://auth_user:changeme@postgres:5432/auth_db?sslmode=disable

# Google OAuth obtenido en console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT: Paths a las claves RSA generadas con:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Dominio permitido
ALLOWED_DOMAIN=@unal.edu.co

# TTL en segundos
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
