# Variables de entorno para el frontend de White OWL
# Copia este archivo a .env y completa los valores

# Token de acceso a Mapbox (requerido)
# Obtén tu token en: https://account.mapbox.com/access-tokens/
# Nota: Usa un token público, no uno secreto
VITE_MAPBOX_TOKEN=tu_token_mapbox_aqui

# URL del backend (opcional, por defecto usa localhost)
VITE_API_URL=http://localhost:3000

# URL del servicio de routing Python (opcional)
VITE_ROUTING_URL=http://localhost:8000
